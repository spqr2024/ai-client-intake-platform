# ── Backend ────────────────────────────────────────────────────────────────
# "production" refuses to boot on unsafe configuration: placeholder JWT_SECRET
# or ADMIN_PASSWORD, DEMO_MODE on, DEBUG on, localhost/wildcard CORS, non-HTTPS
# PUBLIC_APP_URL, or a Telegram token with no webhook secret. Any other value
# only logs those as warnings. Set this to production when you deploy.
ENVIRONMENT=development

# Log verbosity: DEBUG | INFO | WARNING | ERROR (structured JSON output).
LOG_LEVEL=INFO

# Auto-provision a populated demo workspace on first start (leads, chats,
# analytics, KB, pipeline). Great for local demos.
# MUST be false in production: it writes fake leads into the real database.
DEMO_MODE=true
# SQLAlchemy URL. Defaults to a local SQLite file if unset (zero-config dev).
# Docker/Postgres: postgresql+psycopg://intake:intake@db:5432/intake
DATABASE_URL=

# Credentials for the Postgres container in docker-compose.yml. Compose falls
# back to "intake"/"intake" when these are unset, so a deployment that skips
# them runs the database with a password published in this repository.
POSTGRES_USER=intake
POSTGRES_PASSWORD=intake
POSTGRES_DB=intake

# Optional Redis for cluster-wide rate limiting, caching and the task queue.
# Leave empty for single-instance deployments (graceful in-memory fallback).
REDIS_URL=

# Secret used to sign JWT access tokens (32+ random bytes). CHANGE IN PRODUCTION.
JWT_SECRET=change-me-in-production
# Access token lifetime in minutes (refresh tokens rotate for RE-auth).
JWT_EXPIRES_MINUTES=30
REFRESH_TOKEN_DAYS=14
# Brute-force protection: failed logins allowed per email+IP before lockout.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Base URL of the admin app — used for deep links in Telegram/email/in-app notifications.
PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins for the API.
CORS_ORIGINS=http://localhost:3000

# Default admin account created on first startup (if no users exist).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# ── AI providers ───────────────────────────────────────────────────────────
# Active provider: mock | openai | anthropic | gemini | openrouter
# "mock" needs no API key: the deterministic workflow engine drives the chat
# and a rule-based summarizer builds lead summaries. Perfect for local dev.
AI_PROVIDER=mock
AI_MODEL=
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=1024

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Semantic KB retrieval: mock (offline hashing) | openai | gemini | openrouter
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=

# ── Telegram ───────────────────────────────────────────────────────────────
# Create a bot with @BotFather. Leave empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
# Chat id of the manager / group that receives new-lead notifications.
TELEGRAM_CHAT_ID=
# Shared secret Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token
# header. Register it with setWebhook(secret_token=...). Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The webhook FAILS CLOSED: while this is empty the endpoint rejects every
# request (403), because updates it accepts can change lead status and add
# notes. Leaving it unset disables the webhook — it never disables the check.
TELEGRAM_WEBHOOK_SECRET=

# ── Lead notifications ─────────────────────────────────────────────────────
# Inbox that receives "new lead" alerts. Seeds the per-workspace
# `staff_notification_email` setting; a value saved in Settings →
# Notifications still wins at runtime. Leave empty to skip staff emails.
STAFF_NOTIFICATION_EMAIL=

# ── Email (SMTP) ───────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to log emails to console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# ── CRM export ─────────────────────────────────────────────────────────────
# Optional bootstrap for the per-workspace CRM settings, so a deployment can
# ship credentials without an admin clicking through Settings → Integrations.
# A value saved in the admin UI always overrides these.
# hubspot | pipedrive | notion | salesforce | webhook  ("" = disabled)
CRM_PROVIDER=
# HubSpot: a private-app token (pat-…) with crm.objects.contacts.write scope.
CRM_API_KEY=

# ── Scheduled Telegram nudges ──────────────────────────────────────────────
# Daily digest of new leads sent to TELEGRAM_CHAT_ID. Follow-up reminders fire
# when a lead's follow-up date arrives and are unaffected by these.
DIGEST_ENABLED=true
# Hour of day in UTC (0-23) to send it.
DIGEST_HOUR=9

# ── Rate limiting and uploads ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
# Largest accepted attachment, in megabytes.
MAX_UPLOAD_MB=10

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
