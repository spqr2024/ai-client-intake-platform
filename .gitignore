# Node
node_modules/
.next/
out/
npm-debug.log*

# Env & secrets
.env
.env.local
.env.*.local
.env.*
!.env.example
# Credential hand-off documents kept in the working copy by mistake, plus the
# lock files Word leaves beside an open document.
credentials.docx
*credential*.docx
*token*.docx
*password*.docx
*SECRETS*.docx
~$*.docx
~$*.doc
~$*.xlsx
# dmeta unpacks Office files next to the original and leaves the directory
# behind if it cannot rewrite the archive (locked file on Windows).
*_unzipped/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Uploads / runtime data
backend/uploads/
backend/data/
logs/
